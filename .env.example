# Base de datos (PostgreSQL con extensión pgvector habilitada)
DATABASE_URL=postgres://luz:luz@localhost:5432/luz

# Proveedor de IA
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.1

# Worker (Knowledge Engine)
WORKER_POLL_INTERVAL_MS=5000

# Identity Layer (auth/) — Auth.js las lee directamente de process.env,
# no pasan por core/config/env.ts (el dominio no conoce Auth.js).
# AUTH_SECRET es obligatorio en producción (NextAuth lanza error sin él).
AUTH_SECRET=
# Convención de Auth.js: AUTH_<PROVEEDOR>_ID / AUTH_<PROVEEDOR>_SECRET.
# Google es el primer proveedor (ver auth/providers); añadir otro es
# agregarlo a auth/providers/index.ts + sus credenciales aquí.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Observabilidad — emails con acceso a /admin, separados por coma.
# Vacío = /admin cerrado para todos.
ADMIN_EMAILS=
